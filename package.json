{
  "name": "smart-bookmark-manager",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "cd apps/api && npm run dev",
    "dev:web": "cd apps/web && npm run dev",
    "build": "npm run build:web && npm run build:api",
    "build:web": "cd apps/web && npm run build",
    "build:api": "cd apps/api && npm run build",
    "typecheck": "npm run typecheck:web && npm run typecheck:api",
    "typecheck:web": "cd apps/web && npm run typecheck",
    "typecheck:api": "cd apps/api && echo 'No TypeScript checks for API'",
    "lint": "npm run lint:web && npm run lint:api",
    "lint:web": "cd apps/web && npm run lint",
    "lint:api": "cd apps/api && npm run lint",
    "test": "npm run test:api",
    "test:api": "cd apps/api && npm test"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
